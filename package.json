{
  "name": "better-expr-editor",
  "version": "0.1.1",
  "description": "A browser-based editor for the Expr expression language",
  "license": "MIT",
  "type": "module",
  "main": "server.js",
  "bin": {
    "better-expr-editor": "server.js"
  },
  "files": [
    "dist",
    "server.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "wasm": "GOOS=js GOARCH=wasm go build -o public/expr.wasm ./wasm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expr-lang/expr-lang-editor.git"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
